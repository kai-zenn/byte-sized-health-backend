// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum TrendDirection {
  INCREASING
  STABLE
  DECREASING
}

enum Role {
  ADMIN
  USER
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User{
    id            String         @id @default(uuid()) @db.Uuid
    email         String         @unique
    password      String
    name          String
    phone         String         @unique
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt
    role          Role           @default(USER)

    checkIns         DailyCheckIn[]
    weeklyReports    WeeklyReport[]
    monthlyReports   MonthlyReport[]
    refreshTokens    RefreshToken[]
    articles        Article[]

    @@index([email])
    @@map("users")
}

model RefreshToken {
  id          String   @id @unique @default(uuid()) @db.Uuid
  hashedToken String   @unique

  userId      String   @db.Uuid
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expireAt    DateTime

  @@index([userId])
  @@index([hashedToken])
  @@map("refresh_tokens")
}

model DailyCheckIn {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  date      DateTime @db.Date

  // User Input Data
  sleepHours     Float    // Jam tidur (e.g., 7.5)
  workHours      Float    // Jam kerja (e.g., 8.0)
  moodLevel      Int      // 1-10
  stressLevel    Int      // 1-10
  notes          String?  @db.Text

  // // Calculated Metrics, still dont know how to calculate it lol,
  // // whether with LLM or manually in the backend logic, ffs
  // burnoutScore   Float    // Calculated score
  riskLevel      RiskLevel // LOW, MEDIUM, HIGH

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Prevent duplicate check-ins for same day
  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_check_ins")
}

model WeeklyReport {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  weekStart DateTime @db.Date // Monday of the week
  weekEnd   DateTime @db.Date // Sunday of the week

  // Aggregated Metrics
  avgBurnoutScore  Float
  avgMoodLevel     Float
  avgStressLevel   Float
  avgSleepHours    Float
  avgWorkHours     Float

  // Risk Assessment
  overallRiskLevel RiskLevel
  riskIncreased    Boolean   // Compared to previous week

  // Recommendations (JSON array of strings)
  recommendations  Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
  @@map("weekly_reports")
}

model MonthlyReport {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  month     Int      // 1-12
  year      Int      // 2026

  // Aggregated Metrics
  avgBurnoutScore    Float
  avgMoodLevel       Float
  avgStressLevel     Float
  avgSleepHours      Float
  avgWorkHours       Float

  // Trend Analysis
  burnoutTrend       TrendDirection // INCREASING, STABLE, DECREASING
  moodTrend          TrendDirection
  stressTrend        TrendDirection

  // Behavioral Patterns (JSON object with insights)
  behaviorPatterns   Json

  // Strategic Recommendations
  strategies         Json // Array of strategic advice

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId, year, month])
  @@map("monthly_reports")
}

model Article {
  id            String         @id @default(uuid()) @db.Uuid
  title         String
  slug          String         @unique // URL-friendly (auto-generated dari title)
  description   String?        @db.Text // Short summary untuk preview
  content       String         @db.Text // Rich HTML content dari editor
  thumbnail     String?        // URL/path ke thumbnail image
  sources       Json?          // Array of sources: [{title: "...", url: "..."}]

  status        ArticleStatus  @default(DRAFT)
  publishedAt   DateTime?      // Null if draft, set when published

  // Metadata
  authorId      String         @db.Uuid
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)

  viewCount     Int            @default(0)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  images        ArticleImage[] // Track semua images yang di-upload untuk artikel ini
  categories    ArticleCategory[]

  @@index([slug])
  @@index([authorId])
  @@index([status, publishedAt])
  @@map("articles")
}

model ArticleImage {
  id          String   @id @default(uuid()) @db.Uuid
  articleId   String   @db.Uuid
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  filename    String   // Original filename
  path        String   // Path/URL to stored image
  size        Int      // File size in bytes
  mimeType    String   // image/jpeg, image/png, etc

  uploadedAt  DateTime @default(now())

  @@index([articleId])
  @@map("article_images")
}

model Category {
  id          String            @id @default(uuid()) @db.Uuid
  name        String            @unique
  slug        String            @unique
  description String?

  articles    ArticleCategory[]

  createdAt   DateTime          @default(now())

  @@map("categories")
}

model ArticleCategory {
  articleId   String   @db.Uuid
  categoryId  String   @db.Uuid

  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([articleId, categoryId])
  @@map("article_categories")
}
